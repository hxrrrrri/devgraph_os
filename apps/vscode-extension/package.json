{
  "name": "@devgraph/vscode-extension",
  "displayName": "DevGraph OS",
  "description": "Local-first developer knowledge graph integration for VS Code.",
  "version": "0.1.0",
  "publisher": "devgraph",
  "private": true,
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:devgraph.init",
    "onCommand:devgraph.build",
    "onCommand:devgraph.update",
    "onCommand:devgraph.reviewChanges",
    "onCommand:devgraph.explainCurrentFile",
    "onCommand:devgraph.explainSelection",
    "onCommand:devgraph.ask",
    "onCommand:devgraph.searchGraph",
    "onCommand:devgraph.traceFlow",
    "onCommand:devgraph.doctor",
    "onCommand:devgraph.rememberDecision",
    "onCommand:devgraph.showMemories",
    "onCommand:devgraph.openDashboard",
    "onCommand:devgraph.handoff",
    "onCommand:devgraph.copyHandoffPrompt",
    "onCommand:devgraph.openReviewReport",
    "onCommand:devgraph.openOnboardingGuide",
    "onCommand:devgraph.explainSymbol",
    "onCommand:devgraph.reviewSymbol",
    "onLanguage:python",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:javascriptreact"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "DevGraph OS",
      "properties": {
        "devgraph.binaryPath": {
          "type": "string",
          "default": "devgraph",
          "description": "Path to the DevGraph CLI binary."
        },
        "devgraph.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Refresh the DevGraph sidebar after commands."
        },
        "devgraph.dashboardPort": {
          "type": "number",
          "default": 38987,
          "description": "Local dashboard port."
        },
        "devgraph.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show DevGraph Explain / Review impact CodeLens above functions and classes."
        }
      }
    },
    "commands": [
      { "command": "devgraph.init", "title": "DevGraph: Initialize Project" },
      { "command": "devgraph.build", "title": "DevGraph: Build Graph" },
      { "command": "devgraph.update", "title": "DevGraph: Update Graph" },
      { "command": "devgraph.reviewChanges", "title": "DevGraph: Review Current Changes" },
      { "command": "devgraph.explainCurrentFile", "title": "DevGraph: Explain Current File" },
      { "command": "devgraph.explainSelection", "title": "DevGraph: Explain Selection" },
      { "command": "devgraph.ask", "title": "DevGraph: Ask About Project" },
      { "command": "devgraph.searchGraph", "title": "DevGraph: Search Graph" },
      { "command": "devgraph.traceFlow", "title": "DevGraph: Trace Flow from Selection" },
      { "command": "devgraph.doctor", "title": "DevGraph: Run Doctor" },
      { "command": "devgraph.rememberDecision", "title": "DevGraph: Remember Decision" },
      { "command": "devgraph.showMemories", "title": "DevGraph: Show Memories" },
      { "command": "devgraph.openDashboard", "title": "DevGraph: Open Dashboard" },
      { "command": "devgraph.handoff", "title": "DevGraph: Generate Handoff" },
      { "command": "devgraph.copyHandoffPrompt", "title": "DevGraph: Copy Handoff Prompt" },
      { "command": "devgraph.openReviewReport", "title": "DevGraph: Open Review Report" },
      { "command": "devgraph.openOnboardingGuide", "title": "DevGraph: Open Onboarding Guide" },
      { "command": "devgraph.explainSymbol", "title": "DevGraph: Explain Symbol" },
      { "command": "devgraph.reviewSymbol", "title": "DevGraph: Review Symbol Impact" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devgraph",
          "title": "DevGraph",
          "icon": "resources/devgraph.svg"
        }
      ]
    },
    "views": {
      "devgraph": [
        {
          "id": "devgraph.statusView",
          "name": "Project Graph"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "devgraph.explainCurrentFile",
          "group": "navigation@9"
        }
      ],
      "editor/context": [
        {
          "command": "devgraph.explainSelection",
          "group": "navigation@9"
        }
      ],
      "scm/title": [
        {
          "command": "devgraph.reviewChanges",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "devgraph.doctor",
          "when": "view == devgraph.statusView",
          "group": "navigation"
        },
        {
          "command": "devgraph.showMemories",
          "when": "view == devgraph.statusView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/vscode": "^1.92.0",
    "typescript": "^5.6.3"
  }
}
